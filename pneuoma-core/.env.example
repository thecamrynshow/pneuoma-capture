# API authentication (comma-separated, leave empty to disable auth)
PNEUOMA_API_KEYS=

# PNEUOMA AI — the single LLM gateway. All apps point here; PNEUOMA AI sends to vLLM.
PNEUOMA_AI_URL=http://localhost:8000
PNEUOMA_AI_KEY=

# Model (PNEUOMA AI uses this when calling vLLM)
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGING_FACE_HUB_TOKEN=

# Embedding model (runs on CPU)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage paths
CHROMADB_PATH=./data/chromadb
PROFILES_PATH=./data/profiles

# RAG settings
MEMORY_TOP_K=10
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# CORS
ALLOWED_ORIGINS=*
