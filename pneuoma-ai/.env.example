# API authentication — comma-separated list of valid API keys
PNEUOMA_API_KEYS=your-api-key-here

# Whisper configuration
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# vLLM configuration (the sidecar LLM server)
VLLM_BASE_URL=http://localhost:8001/v1
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Hugging Face token (required to download Llama model)
HUGGING_FACE_HUB_TOKEN=your-hf-token-here

# CORS — comma-separated origins, or * for all
ALLOWED_ORIGINS=*
