# Database (Supabase PostgreSQL — get from Project Settings > Database)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

# Auth (required for login/signup)
NEXTAUTH_SECRET="your-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"
# For Vercel: NEXTAUTH_URL="https://your-app.vercel.app"

# AI — Option A: Replicate (pay-per-use, recommended for Vercel)
REPLICATE_API_TOKEN="r8_..."

# AI — Option B: Self-hosted PNEUOMA AI (legacy VM)
# PNEUOMA_AI_URL="http://localhost:8000"
# PNEUOMA_AI_KEY="pneuoma-..."

# When app is bundled locally (Capacitor without server.url)
# NEXT_PUBLIC_API_URL="https://your-app.vercel.app"
